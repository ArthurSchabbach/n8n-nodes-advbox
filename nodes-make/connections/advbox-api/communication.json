{
	"url": "https://app.advbox.com.br/api/v1/settings",
	"method": "GET",
	"headers": {
		"Authorization": "Bearer {{parameters.apiToken}}",
		"Accept": "application/json"
	},
	"response": {
		"valid": "{{statusCode === 200}}",
		"error": {
			"message": "[{{statusCode}}] {{body.message}}"
		}
	},
	"log": {
		"sanitize": ["request.headers.authorization"]
	}
}
