[
	{
		"name": "users_id",
		"type": "select",
		"label": "Responsible User",
		"required": true,
		"options": {
			"store": "rpc://loadUsers"
		},
		"help": "Responsible user for the lawsuit."
	},
	{
		"name": "customers_id",
		"type": "text",
		"label": "Customer IDs",
		"required": true,
		"help": "Customer ID(s). Comma-separated for multiple (e.g. 1,2,3)."
	},
	{
		"name": "stages_id",
		"type": "select",
		"label": "Stage",
		"required": true,
		"options": {
			"store": "rpc://loadStages"
		},
		"help": "Initial stage of the lawsuit."
	},
	{
		"name": "type_lawsuits_id",
		"type": "select",
		"label": "Lawsuit Type",
		"required": true,
		"options": {
			"store": "rpc://loadLawsuitTypes"
		},
		"help": "Type of the lawsuit."
	},
	{
		"name": "additionalFields",
		"type": "collection",
		"label": "Additional Fields",
		"spec": [
			{
				"name": "process_number",
				"type": "text",
				"label": "Process Number"
			},
			{
				"name": "protocol_number",
				"type": "text",
				"label": "Protocol Number"
			},
			{
				"name": "folder",
				"type": "text",
				"label": "Folder"
			},
			{
				"name": "date",
				"type": "date",
				"label": "Date"
			},
			{
				"name": "notes",
				"type": "text",
				"label": "Notes"
			},
			{
				"name": "lawsuit_groups_id",
				"type": "select",
				"label": "Lawsuit Group",
				"options": {
					"store": "rpc://loadLawsuitGroups"
				}
			}
		]
	}
