{
  "name": "n8n-nodes-advbox",
  "version": "1.0.48",
  "description": "n8n community node for ADVBOX API - manage customers, lawsuits, tasks, movements, transactions and settings",
  "keywords": [
    "n8n-community-node-package",
    "advbox",
    "api",
    "legal",
    "law",
    "crm"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ArthurSchabbach/n8n-nodes-advbox#readme",
  "author": {
    "name": "ADVBOX",
    "email": "developer@advbox.com.br"
  },
  "main": "index.js",
  "engines": {
    "n8n": ">=0.125.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArthurSchabbach/n8n-nodes-advbox.git"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes/ credentials/ --ext .ts",
    "lintfix": "eslint nodes/ credentials/ --ext .ts --fix"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AdvboxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Advbox/Advbox.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.82.0",
    "typescript": "~5.5.0"
  }
}
